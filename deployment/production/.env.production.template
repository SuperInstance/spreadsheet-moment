# Production Environment Variables Template
# Copy this file to .env.production and fill in the values

# ============================================================================
# CLAW API CONFIGURATION
# ============================================================================

# Claw API base URL (required)
CLAW_API_BASE_URL=https://api.example.com

# Claw API key (required, minimum 20 characters)
CLAW_API_KEY=your-production-api-key-here

# WebSocket URL (optional, defaults to ws(s)://CLAW_API_BASE_URL)
CLAW_WS_URL=wss://api.example.com/ws

# ============================================================================
# REQUEST CONFIGURATION
# ============================================================================

# Request timeout in milliseconds (default: 30000)
CLAW_REQUEST_TIMEOUT=30000

# Maximum retry attempts (default: 5)
CLAW_MAX_RETRIES=5

# Initial retry delay in milliseconds (default: 1000)
CLAW_INITIAL_RETRY_DELAY=1000

# Maximum retry delay in milliseconds (default: 30000)
CLAW_MAX_RETRY_DELAY=30000

# Retry backoff multiplier (default: 2)
CLAW_RETRY_BACKOFF_MULTIPLIER=2

# ============================================================================
# WEBSOCKET CONFIGURATION
# ============================================================================

# WebSocket reconnection interval in milliseconds (default: 5000)
CLAW_WS_RECONNECT_INTERVAL=5000

# Maximum WebSocket reconnection delay in milliseconds (default: 60000)
CLAW_MAX_WS_RECONNECT_DELAY=60000

# Maximum WebSocket reconnection attempts (default: 10)
CLAW_MAX_WS_RECONNECT_ATTEMPTS=10

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================

# Enable metrics collection (default: true)
CLAW_METRICS_ENABLED=true

# Enable debug logging for metrics (default: false)
CLAW_METRICS_DEBUG=false

# Metrics sampling rate 0-1 (default: 1.0)
CLAW_METRICS_SAMPLING_RATE=1.0

# ============================================================================
# HEALTH CHECK CONFIGURATION
# ============================================================================

# Enable health checks (default: true)
CLAW_HEALTH_CHECK_ENABLED=true

# Health check interval in milliseconds (default: 60000)
CLAW_HEALTH_CHECK_INTERVAL=60000

# Health check timeout in milliseconds (default: 5000)
CLAW_HEALTH_CHECK_TIMEOUT=5000

# Health check failure threshold (default: 3)
CLAW_HEALTH_CHECK_FAILURE_THRESHOLD=3

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node environment (development, production)
NODE_ENV=production

# Server port (default: 3000)
PORT=3000

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Application version
APP_VERSION=1.0.0

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# AWS Region (if using AWS)
AWS_REGION=us-east-1

# Deployment environment (development, staging, production)
DEPLOYMENT_ENVIRONMENT=production

# Feature flags
FEATURE_WEBSOCKET=true
FEATURE_METRICS=true
FEATURE_HEALTH_CHECKS=true
FEATURE_CACHING=true

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Enable HTTPS (default: true)
HTTPS_ENABLED=true

# TLS min version (TLSv1, TLSv1.1, TLSv1.2, TLSv1.3)
TLS_MIN_VERSION=TLSv1.2

# Enable CORS
CORS_ENABLED=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://example.com,https://app.example.com

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Redis URL (if using caching)
REDIS_URL=redis://localhost:6379

# Database URL (if using database)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Sentry DSN (if using Sentry for error tracking)
SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=100

# Request queue size
REQUEST_QUEUE_SIZE=1000

# Connection pool size
CONNECTION_POOL_SIZE=10

# Keep-alive timeout
KEEP_ALIVE_TIMEOUT=60000

# Headers timeout
HEADERS_TIMEOUT=60000

# ============================================================================
# DEVELOPMENT/DEBUGGING
# ============================================================================

# Enable debug mode (default: false, do not enable in production)
DEBUG=false

# Enable request logging (default: false)
REQUEST_LOGGING=false

# Enable response logging (default: false)
RESPONSE_LOGGING=false

# Enable error logging (default: true)
ERROR_LOGGING=true
