# Spreadsheet Moment - Staging Environment Configuration
# Template for staging deployment environment variables
#
# Setup Instructions:
# 1. Copy this file to .env.staging
# 2. Fill in all required values
# 3. Never commit .env.staging to version control

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
NODE_ENV=staging
ENVIRONMENT=staging
REGION=us-east-1
DEPLOYMENT_TIMESTAMP=2026-03-16T00:00:00Z

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=spreadsheet-moment-staging
APP_VERSION=0.1.0
APP_URL=https://staging.spreadsheet-moment.superinstance.ai
API_URL=https://staging-api.spreadsheet-moment.superinstance.ai
WS_URL=wss://staging-api.spreadsheet-moment.superinstance.ai

# Port configuration
PORT=3000
HEALTH_CHECK_PORT=3001

# ============================================================================
# DATABASE SETTINGS
# ============================================================================
# PostgreSQL Database
DATABASE_URL=postgresql://username:password@staging-db.example.com:5432/spreadsheet_moment_staging
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=true

# Redis Cache
REDIS_URL=redis://staging-redis.example.com:6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ============================================================================
# CLOUDFLARE SETTINGS
# ============================================================================
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# KV Namespaces
CF_KV_CELL_DATA_ID=your-cell-data-kv-id
CF_KV_CELL_DATA_PREVIEW_ID=your-cell-data-preview-kv-id
CF_KV_SPREADSHEET_METADATA_ID=your-metadata-kv-id
CF_KV_SPREADSHEET_METADATA_PREVIEW_ID=your-metadata-preview-kv-id

# D1 Database
CF_D1_DATABASE_ID=your-d1-database-id
CF_D1_DATABASE_NAME=spreadsheet_moment_staging_db

# R2 Storage
CF_R2_BUCKET_NAME=spreadsheet-moment-staging-files

# ============================================================================
# CLAW API INTEGRATION
# ============================================================================
CLAW_API_URL=https://staging-api.claw.superinstance.ai
CLAW_API_WS_URL=wss://staging-api.claw.superinstance.ai/ws
CLAW_API_KEY=your-claw-api-key-staging
CLAW_API_TIMEOUT=30000
CLAW_MAX_CONCURRENT=50

# ============================================================================
# AI/ML API KEYS
# ============================================================================
# DeepSeek API (Primary - $0.014/1K tokens)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# OpenAI API (Backup)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_URL=https://api.openai.com/v1

# Anthropic API (Backup)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_URL=https://api.anthropic.com/v1

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Settings
JWT_SECRET=your-jwt-secret-staging-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session Management
SESSION_SECRET=your-session-secret-staging-min-32-chars
SESSION_MAX_AGE=604800000

# API Keys
API_KEY_HEADER=X-API-Key
API_KEY_VALIDITY_DAYS=365

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_FAILED_REQUESTS=true

# CORS Settings
CORS_ENABLED=true
CORS_ORIGIN=https://staging.spreadsheet-moment.superinstance.ai
CORS_CREDENTIALS=true

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Application Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/spreadsheet-moment

# Metrics Collection
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Distributed Tracing
TRACE_ENABLED=true
TRACE_EXPORTER=jaeger
TRACE_ENDPOINT=http://jaeger-collector:14268/api/traces
TRACE_SAMPLE_RATIO=0.1

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_AGENT_VISUALIZATION=true
FEATURE_TRACE_VIEWER=true
FEATURE_EQUIPMENT_MANAGEMENT=true
FEATURE_NATURAL_LANGUAGE_BUILDER=false
FEATURE_SPATIAL_DEBUGGER=false

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================
# Cache Settings
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Connection Limits
MAX_WEBSOCKET_CONNECTIONS=1000
MAX_CONCURRENT_AGENTS=500
MAX_CELLS_PER_SPREADSHEET=10000
MAX_SPREADSHEETS_PER_USER=100

# Request Limits
MAX_REQUEST_SIZE_MB=10
MAX_UPLOAD_SIZE_MB=50

# ============================================================================
# BACKUP & RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_BUCKET=spreadsheet-moment-staging-backups

# ============================================================================
# NOTIFICATIONS
# ============================================================================
# Email Notifications (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@staging.superinstance.ai

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#spreadsheet-moment-staging

# ============================================================================
# TESTING SETTINGS
# ============================================================================
# Test Mode Settings
TEST_MODE=false
MOCK_CLAW_API=false
MOCK_AI_APIS=false
DEMO_MODE_ENABLED=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
DEBUG=true
VERBOSE_LOGGING=true
PROFILING_ENABLED=true
HOT_RELOAD=false
SOURCE_MAPS=true

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# GitHub Integration (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Google Analytics (optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# COMPLIANCE & PRIVACY
# ============================================================================
# Data Privacy
DATA_RETENTION_DAYS=90
ANONYMIZE_LOGS=true
COOKIE_CONSENT_ENABLED=false

# Security Headers
HELIOS_DETECTION_ENABLED=false
CSP_ENABLED=false
HSTS_ENABLED=false

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================
DEPLOYMENT_PLATFORM=cloudflare
DEPLOYMENT_STRATEGY=rolling
DEPLOYMENT_HEALTH_CHECK_TIMEOUT=300
DEPLOYMENT_ROLLOUT_PERCENTAGE=25

# Zero-Downtime Settings
ZERO_DOWNTIME_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_FAILURE_THRESHOLD=3
HEALTH_CHECK_SUCCESS_THRESHOLD=2
